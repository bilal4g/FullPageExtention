# Microsoft Edge Add-ons API credentials.
# Copy this file to ".env" and fill in real values, OR set these as real
# environment variables in your shell / CI. NEVER commit real secrets.
#
# Create them in Microsoft Partner Center:
#   Edge program -> Publish API -> "Create API credentials".

EDGE_CLIENT_ID=your-client-id
EDGE_API_KEY=your-api-key
EDGE_PRODUCT_ID=your-product-id
